# MongoDB connection (Atlas connection string or self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=alum-design

# Admin panel (/admin) — protect with a strong password
# Generate a bcrypt hash, e.g.:
#   node -e "require('bcryptjs').hash(process.argv[1], 10).then(console.log)" "your-strong-password"
#
# IMPORTANT: bcrypt hashes contain "$" (e.g. $2b$10$...). Next.js expands
# "$name" in .env files as a variable reference, which corrupts the hash.
# Escape every "$" as "\$" when pasting the hash here (and in Vercel env vars
# this is not needed — only local .env files go through dotenv-expand), e.g.:
#   ADMIN_PASSWORD_HASH=\$2b\$10\$abcdefgh...
ADMIN_PASSWORD_HASH=

# Random long string used to sign admin session cookies, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
