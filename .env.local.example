# MongoDB connection (Atlas connection string or self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=alum-design

# Admin panel (/admin) — no password setup needed here.
# The first password you type into /admin/login is hashed (bcrypt) and stored
# in MongoDB as the permanent admin password. Every later login is checked
# against that stored hash — just keep using the same password.

# Random long string used to sign admin session cookies, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Cloudinary (image library — admin can upload images and pick them for site sections)
# Find these in your Cloudinary dashboard under Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (transactional email — new-lead notifications + auto-reply to the lead)
# Get an API key at https://resend.com/api-keys
# RESEND_FROM_EMAIL must be on a domain verified in your Resend account
RESEND_API_KEY=
RESEND_FROM_EMAIL=ALUM DESIGN <leads@yourdomain.co.il>
RESEND_NOTIFY_TO=info@alum-design.co.il
