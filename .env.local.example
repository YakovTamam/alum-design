# MongoDB connection (Atlas connection string or self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=alum-design

# Admin panel (/admin) — role-based accounts (super-admin / admin / client),
# stored in the "users" MongoDB collection.
# The first time anyone submits /admin/login while the "users" collection is
# empty, that account is created as the super-admin. Every account after that
# is created via an emailed invitation link (see RESEND settings below).

# Random long string used to sign session cookies (admin + client), e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Cloudinary (image library — admin can upload images and pick them for site sections)
# Find these in your Cloudinary dashboard under Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (transactional email — new-lead notifications, auto-reply to the
# lead, and account invitation emails for /admin and /client)
# Get an API key at https://resend.com/api-keys
# RESEND_FROM_EMAIL must be on a domain verified in your Resend account
RESEND_API_KEY=
RESEND_FROM_EMAIL=ALUM DESIGN <leads@yourdomain.co.il>
RESEND_NOTIFY_TO=info@alum-design.co.il
